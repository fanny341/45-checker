<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="2dp" app:cardCornerRadius="8dp" app:cardElevation="1dp">
    <LinearLayout android:orientation="horizontal" android:padding="12dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:id="@+id/tvSales" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="15sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvTrans" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="#888" android:layout_marginEnd="8dp" />
        <TextView android:id="@+id/tvTotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="15sp" android:textColor="#E53935" android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
